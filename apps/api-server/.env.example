# Server
PORT=5000
CLIENT_URL=http://localhost:4200

# Database
# Use the Docker service name 'db' as the host when running inside Docker Compose
DATABASE_URL=postgresql://gsc_user:gsc_pass@db:5432/gsc_db
# Use localhost and the mapped port for local development outside Docker
# DATABASE_URL=postgresql://gsc_user:gsc_pass@localhost:5433/gsc_db

# Google Gemini API
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyD0MXLfxp89JRTGR-LRbm99FO0dml59fS0

# Google Cloud Platform (for Speech-to-Text, Vision, Translate)
# Path to your GCP service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./src/config/gcp-service-key.json

# Firebase Admin SDK
# The firebase-service-account.json file should be placed at the backend root
# Download it from Firebase Console > Project Settings > Service Accounts
FIREBASE_SERVICE_ACCOUNT=./src/config/firebase-service-account.json

# Hugging Face (for free open-source LLM inference)
# Get a free token from https://huggingface.co/settings/tokens
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN

# Cloudinary (for media and PDF storage)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Email and email app password
EMAIL=your_email@gmail.com
EMAIL_PASS=your_app_password